# Firebase Web SDK (public)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=paytochat.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=paytochat
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=paytochat.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (server-only). Get from a service account JSON.
FIREBASE_ADMIN_PROJECT_ID=paytochat
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxx@paytochat.iam.gserviceaccount.com
# Wrap the private key in quotes; the literal \n sequences will be expanded at runtime.
FIREBASE_ADMIN_PRIVATE_KEY=""

# WalletConnect Cloud project id (free at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional: custom RPC endpoints. Defaults are public RPCs which can be rate-limited.
# Per-chain `NEXT_PUBLIC_*` vars feed wagmi (browser reads) and the
# corresponding bare vars feed server-side verifiers in /api/messages/*.
NEXT_PUBLIC_ETH_RPC_URL=
NEXT_PUBLIC_SOL_RPC_URL=
ETH_RPC_URL=
SOL_RPC_URL=

# Browser-side per-chain RPCs (used by wagmi for read calls / receipts).
NEXT_PUBLIC_SEPOLIA_RPC_URL=
NEXT_PUBLIC_BASE_RPC_URL=
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=
NEXT_PUBLIC_ARBITRUM_RPC_URL=
NEXT_PUBLIC_OPTIMISM_RPC_URL=
NEXT_PUBLIC_POLYGON_RPC_URL=

# Server-side per-chain RPCs (used by /api/messages/{send,claim,refund} for
# Deposited / Claimed / Refunded event verification). Public defaults work
# but rate-limit; configure your own for production.
SEPOLIA_RPC_URL=
BASE_RPC_URL=
BASE_SEPOLIA_RPC_URL=
ARBITRUM_RPC_URL=
OPTIMISM_RPC_URL=
POLYGON_RPC_URL=

# --------------------------- Escrow ---------------------------
# Which EVM chain the send-with-pay form targets. Chain IDs:
#   1=Ethereum, 11155111=Sepolia, 8453=Base, 84532=BaseSepolia,
#   42161=Arbitrum, 10=Optimism, 137=Polygon.
NEXT_PUBLIC_DEFAULT_EVM_CHAIN_ID=11155111

# How many days a deposit stays locked before the sender can refund it.
NEXT_PUBLIC_ESCROW_DEFAULT_DEADLINE_DAYS=7

# Deployed PayToChatEscrow contract addresses, keyed by chain id. The
# *_PUBLIC_* copy is read by the browser; the bare copy is read server-side
# in API routes and is the one the verifier actually trusts.
#
# Example (your Sepolia + mainnet deploys):
NEXT_PUBLIC_ESCROW_ADDRESS_11155111=0xB43b70e04c2CF7E2306EE1d29465ec70C68a8ed2
ESCROW_ADDRESS_11155111=0xB43b70e04c2CF7E2306EE1d29465ec70C68a8ed2
NEXT_PUBLIC_ESCROW_ADDRESS_1=0x09f62637e267aA2B3Ec5a9F70f8739803b3a9715
ESCROW_ADDRESS_1=0x09f62637e267aA2B3Ec5a9F70f8739803b3a9715
# NEXT_PUBLIC_ESCROW_ADDRESS_8453=
# ESCROW_ADDRESS_8453=
# NEXT_PUBLIC_ESCROW_ADDRESS_42161=
# ESCROW_ADDRESS_42161=

# SendGrid (server-only). Used to email recipients when they get a new message.
# Create an API key at https://app.sendgrid.com/settings/api_keys with the
# "Mail Send" permission, then verify the FROM address as a Single Sender or
# via domain authentication.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=notifications@paytochat.fun
SENDGRID_FROM_NAME=Pay to Chat

# Public base URL used in transactional emails (links to the inbox / settings).
NEXT_PUBLIC_APP_URL=https://paytochat.fun
