# Firebase Web SDK (public)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=paytochat.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=paytochat
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=paytochat.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (server-only). Get from a service account JSON.
FIREBASE_ADMIN_PROJECT_ID=paytochat
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxx@paytochat.iam.gserviceaccount.com
# Wrap the private key in quotes; the literal \n sequences will be expanded at runtime.
FIREBASE_ADMIN_PRIVATE_KEY=""

# WalletConnect Cloud project id (free at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional: custom RPC endpoints. Defaults are public RPCs which can be rate-limited.
NEXT_PUBLIC_ETH_RPC_URL=
NEXT_PUBLIC_SOL_RPC_URL=
ETH_RPC_URL=
SOL_RPC_URL=
