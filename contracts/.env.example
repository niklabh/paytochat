# Used only when deploying / verifying. Never commit real values.
#
# IMPORTANT: do NOT put a private key in this file. Use the encrypted
# keystore flow instead — see contracts/README.md > "Secure key handling".
# The DEPLOYER_PRIVATE_KEY var below exists only for CI fallback.

# Path to an encrypted JSON keystore (default: ~/.paytochat/deployer-keystore.json).
# Generate one with `npx hardhat run scripts/generate-keystore.ts`.
# KEYSTORE_PATH=

# CI / legacy fallback — plaintext private key. Avoid for production keys;
# rotate immediately if this ever lands in chat history, a backup, git, etc.
# DEPLOYER_PRIVATE_KEY=

# --- RPC endpoints --------------------------------------------------------
# Mainnets
ETH_RPC_URL=https://mainnet.infura.io/v3/your-key
BASE_RPC_URL=https://mainnet.base.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io
POLYGON_RPC_URL=https://polygon-rpc.com

# Testnets
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your-key
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# --- Block explorer API key (for `hardhat verify`) -----------------------
# A single etherscan.io key works for ALL chains Etherscan supports
# (Ethereum + Base + Arbitrum + Optimism + Polygon + L2s) via the V2
# unified API. Get one free at https://etherscan.io/myapikey.
# The per-chain keys below are legacy fallbacks; only set them if you
# don't have an etherscan.io account at all.
ETHERSCAN_API_KEY=
# BASESCAN_API_KEY=
# ARBISCAN_API_KEY=
# OPTIMISTIC_ETHERSCAN_API_KEY=
# POLYGONSCAN_API_KEY=

# --- Deployment parameters ----------------------------------------------
# Address that should own the contract after deployment (admin / fee
# recipient). Strongly recommend a Safe multisig for production. If empty,
# the deployer becomes the initial owner.
INITIAL_OWNER=

# Initial fee in basis points (100 = 1%). Capped at 1000 (10%) by the contract.
INITIAL_FEE_BPS=250

# Stablecoin addresses to allowlist on deploy. The deploy script only
# allowlists when the deployer is also the owner — otherwise the multisig
# has to do it post-deploy.
#
# Defaults below are USDC / USDT / USDG on Ethereum mainnet. Override per network:
#   Base:     USDC=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
#   Arbitrum: USDC=0xaf88d065e77c8cC2239327C5EDb3A432268e5831
#             USDT=0xFd086bC7CD5C481DCC9C85ebE478A1C0b69FCbb9
#   Optimism: USDC=0x0b2C639c533813f4Aa9D7837CAf62653d097Ff85
#             USDT=0x94b008aA00579c1307B0EF2c499aD98a8ce58e58
#   Polygon:  USDC=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
#             USDT=0xc2132D05D31c914a87C6611C10748AEb04B58e8F
# USDG (Paxos Global Dollar) is currently only on Ethereum mainnet, Ink,
# and X Layer — leave USDG_ADDRESS blank on networks where it doesn't
# exist yet. See https://docs.paxos.com/guides/stablecoin/usdg/mainnet.
USDC_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
USDT_ADDRESS=0xdAC17F958D2ee523a2206206994597C13D831ec7
USDG_ADDRESS=0xe343167631d89B6Ffc58B88d6b7fB0228795491D
