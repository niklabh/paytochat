rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Message attachments uploaded by a sender before the message is created.
    // Public read so recipients (and the sender preview) can fetch them.
    // Write is restricted to the authenticated owner under their own folder,
    // size capped at 8 MB, and only image MIME types allowed.
    match /message-images/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|jpg|gif|webp|avif)');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
